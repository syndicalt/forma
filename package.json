{
  "name": "forma-lang-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "check": "corepack pnpm -r run check",
    "test": "corepack pnpm -r run test",
    "test:ts": "corepack pnpm --filter @forma-lang/forma test && corepack pnpm --filter @forma-lang/cli test",
    "test:tree-sitter": "corepack pnpm --filter tree-sitter-forma test",
    "docs:check": "node scripts/check-docs.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
