{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormaPackageManifest",
  "type": "object",
  "required": ["formaPackage", "name", "version", "tasks", "evalSuite", "compatibility"],
  "additionalProperties": false,
  "properties": {
    "formaPackage": { "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*(/[a-z0-9][a-z0-9-]*)?$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "sourceSha256"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "sourceSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "evalSuite": { "type": "string" },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "source", "output"],
        "additionalProperties": false,
        "properties": {
          "target": { "enum": ["typescript", "python"] },
          "source": { "type": "string" },
          "output": { "type": "string" }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runtime", "path"],
        "additionalProperties": false,
        "properties": {
          "runtime": { "enum": ["typescript", "python"] },
          "path": { "type": "string" }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["breaking", "review", "environment"],
      "additionalProperties": false,
      "properties": {
        "breaking": {
          "type": "array",
          "items": { "type": "string" }
        },
        "review": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environment": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
