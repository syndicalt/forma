{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "forma",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "task_declaration"
      }
    },
    "task_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "task"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_task_member"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_task_member": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "intent_block"
        },
        {
          "type": "SYMBOL",
          "name": "input_block"
        },
        {
          "type": "SYMBOL",
          "name": "output_block"
        },
        {
          "type": "SYMBOL",
          "name": "compute_block"
        },
        {
          "type": "SYMBOL",
          "name": "agent_block"
        },
        {
          "type": "SYMBOL",
          "name": "permissions_block"
        },
        {
          "type": "SYMBOL",
          "name": "constraints_block"
        },
        {
          "type": "SYMBOL",
          "name": "verify_block"
        }
      ]
    },
    "intent_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "intent"
        },
        {
          "type": "SYMBOL",
          "name": "_string"
        }
      ]
    },
    "input_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "input"
        },
        {
          "type": "SYMBOL",
          "name": "_field_block"
        }
      ]
    },
    "output_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "output"
        },
        {
          "type": "SYMBOL",
          "name": "_field_block"
        }
      ]
    },
    "compute_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "compute"
        },
        {
          "type": "SYMBOL",
          "name": "_raw_block"
        }
      ]
    },
    "agent_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "agent"
        },
        {
          "type": "SYMBOL",
          "name": "_raw_block"
        }
      ]
    },
    "permissions_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "permissions"
        },
        {
          "type": "SYMBOL",
          "name": "_raw_block"
        }
      ]
    },
    "constraints_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "constraints"
        },
        {
          "type": "SYMBOL",
          "name": "_raw_block"
        }
      ]
    },
    "verify_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "verify"
        },
        {
          "type": "SYMBOL",
          "name": "_raw_block"
        }
      ]
    },
    "_field_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_field_declaration"
              },
              {
                "type": "SYMBOL",
                "name": "object_schema"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_field_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "_field_identifier"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "FIELD",
          "name": "type",
          "content": {
            "type": "SYMBOL",
            "name": "_type_reference"
          }
        }
      ]
    },
    "object_schema": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "object"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_field_block"
        }
      ]
    },
    "_type_reference": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_field_identifier"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "[]"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "?"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_raw_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_triple_string"
              },
              {
                "type": "PATTERN",
                "value": "[^{}\"]+"
              },
              {
                "type": "SYMBOL",
                "name": "_string"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\]"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\."
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "_triple_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\"\"\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"]"
                },
                {
                  "type": "PATTERN",
                  "value": "\"[^\"]"
                },
                {
                  "type": "PATTERN",
                  "value": "\"\"[^\"]"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\"\"\""
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "_field_identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}